# Vite (see https://vitejs.dev/guide/env-and-mode.html) — copy to .env and fill in values.
# The publishable/anon key is public by design; still avoid committing a real .env in shared branches if your policy requires it.

VITE_SUPABASE_URL=
# Supabase "anon" / publishable key (Lovable: often labeled as publishable)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: same value as the publishable key, if you prefer a second name in tooling
# VITE_SUPABASE_ANON_KEY=
